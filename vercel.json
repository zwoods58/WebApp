{
  "version": 2,
  "builds": [
    {
      "src": "modern-website/package.json",
      "use": "@vercel/next"
    }
  ],
  "routes": [
    {
      "handle": "filesystem"
    },
    {
      "src": "/Beezee-App/(.*)",
      "dest": "/modern-website/Beezee-App/$1"
    },
    {
      "src": "/sw.js",
      "dest": "/modern-website/sw.js"
    },
    {
      "src": "/manifest.json",
      "dest": "/modern-website/manifest.json"
    },
    {
      "src": "/kenya/app/(.*)",
      "dest": "/modern-website/kenya/app/$1"
    },
    {
      "src": "/nigeria/app/(.*)",
      "dest": "/modern-website/nigeria/app/$1"
    },
    {
      "src": "/south-africa/app/(.*)",
      "dest": "/modern-website/south-africa/app/$1"
    }
  ],
  "headers": [
    {
      "source": "/(.*)",
      "headers": [
        {
          "key": "X-Content-Type-Options",
          "value": "nosniff"
        },
        {
          "key": "X-Frame-Options", 
          "value": "DENY"
        },
        {
          "key": "X-XSS-Protection",
          "value": "1; mode=block"
        },
        {
          "key": "Referrer-Policy",
          "value": "strict-origin-when-cross-origin"
        }
      ]
    },
    {
      "source": "/api/(.*)",
      "headers": [
        {
          "key": "Cache-Control",
          "value": "no-store, must-revalidate"
        },
        {
          "key": "Access-Control-Allow-Credentials",
          "value": "true"
        },
        {
          "key": "Access-Control-Allow-Origin",
          "value": "*"
        },
        {
          "key": "Access-Control-Allow-Methods",
          "value": "GET,DELETE,PATCH,POST,PUT,OPTIONS"
        },
        {
          "key": "Access-Control-Allow-Headers",
          "value": "X-CSRF-Token, X-Requested-With, Accept, Accept-Version, Content-Length, Content-MD5, Content-Type, Date, X-Api-Version, Authorization"
        }
      ]
    },
    {
      "source": "/_next/static/(.*)",
      "headers": [
        {
          "key": "Cache-Control",
          "value": "public, max-age=31536000, immutable"
        }
      ]
    },
    {
      "source": "/favicon.ico",
      "headers": [
        {
          "key": "Cache-Control", 
          "value": "public, max-age=86400"
        }
      ]
    }
  ],
  "functions": {
    "src/app/api/**/*.ts": {
      "maxDuration": 30
    }
  },
  "build": {
    "env": {
      "NEXT_PUBLIC_SITE_URL": "https://web-app1-dsvkfjaqz-zwoods58s-projects.vercel.app"
    }
  }
}
