/**
 * Background Sync Service
 * Handles intelligent background synchronization with retry logic,
 * network quality detection, and conflict resolution.
 */

import { getQueue, addToQueue, removeFromQueue } from './offlineQueue';

export interface SyncMetrics {
  totalOperations: number;
  successfulOperations: number;
  failedOperations: number;
  averageSyncTime: number;
  lastSyncTime: number;
  retryCount: number;
}

export interface NetworkQuality {
  type: 'excellent' | 'good' | 'poor' | 'offline';
  speed: number;
  reliability: number;
  recommendedBatchSize: number;
  timeout: number;
}

export class BackgroundSyncService {
  private static instance: BackgroundSyncService;
  private isRunning: boolean = false;
  private syncInterval: NodeJS.Timeout | null = null;
  private metrics: SyncMetrics;
  private networkQuality: NetworkQuality;
  private retryQueue: Map<string, any> = new Map();
  private listeners: Set<(status: string) => void> = new Set();

  private constructor() {
    this.metrics = {
      totalOperations: 0,
      successfulOperations: 0,
      failedOperations: 0,
      averageSyncTime: 0,
      lastSyncTime: 0,
      retryCount: 0
    };

    this.networkQuality = this.detectNetworkQuality();
    this.setupNetworkMonitoring();
  }

  static getInstance(): BackgroundSyncService {
    if (!BackgroundSyncService.instance) {
      BackgroundSyncService.instance = new BackgroundSyncService();
    }
    return BackgroundSyncService.instance;
  }

  /**
   * Start the background sync service
   */
  start() {
    if (this.isRunning) return;

    console.log('🔄 Starting Background Sync Service');
    this.isRunning = true;

    // Immediate sync attempt
    this.processSync();

    // Set up periodic sync
    this.syncInterval = setInterval(() => {
      if (navigator.onLine) {
        this.processSync();
      }
    }, 30000); // Sync every 30 seconds

    // Set up network change listeners
    this.setupNetworkListeners();
  }

  /**
   * Stop the background sync service
   */
  stop() {
    if (!this.isRunning) return;

    console.log('⏹️ Stopping Background Sync Service');
    this.isRunning = false;

    if (this.syncInterval) {
      clearInterval(this.syncInterval);
      this.syncInterval = null;
    }
  }

  /**
   * Force immediate sync
   */
  async forceSync(): Promise<boolean> {
    console.log('⚡ Force sync requested');
    return this.processSync();
  }

  /**
   * Main sync processing logic
   */
  private async processSync(): Promise<boolean> {
    const startTime = Date.now();
    
    try {
      this.notifyListeners('sync-starting');
      
      if (!navigator.onLine) {
        console.log('📴 No connection, skipping sync');
        this.notifyListeners('sync-offline');
        return false;
      }

      // Get pending operations
      const queueStats = await getQueue();
      const pendingOps = queueStats.length;
      if (pendingOps === 0) {
        console.log('✅ No pending operations');
        this.notifyListeners('sync-complete');
        return true;
      }

      // Get all pending operations from queue
      const allOperations: any[] = [];
      ['cash', 'inventory', 'calendar', 'credit', 'beehive'].forEach(feature => {
        const ops = offlineQueueManager.getOperationsByFeature(feature);
        allOperations.push(...ops.filter(op => op.status === 'pending'));
      });

      // Group operations by priority and type
      const groupedOps = this.groupOperations(allOperations);
      
      // Process in priority order
      let successCount = 0;
      let failureCount = 0;

      for (const [priority, operations] of groupedOps) {
        const batchSize = this.networkQuality.recommendedBatchSize;
        const batches = this.createBatches(operations, batchSize);

        for (const batch of batches) {
          const results = await this.processBatch(batch);
          successCount += results.success;
          failureCount += results.failure;
        }
      }

      // Update metrics
      this.updateMetrics(startTime, successCount, failureCount);
      
      console.log(`📊 Sync completed: ${successCount} success, ${failureCount} failures`);
      this.notifyListeners(failureCount > 0 ? 'sync-partial' : 'sync-complete');
      
      return failureCount === 0;

    } catch (error) {
      console.error('❌ Sync failed:', error);
      this.metrics.failedOperations++;
      this.notifyListeners('sync-error');
      return false;
    }
  }

  /**
   * Process a batch of operations
   */
  private async processBatch(operations: any[]): Promise<{ success: number; failure: number }> {
    const results = { success: 0, failure: 0 };

    for (const operation of operations) {
      try {
        const success = await this.processOperation(operation);
        if (success) {
          results.success++;
          offlineQueueManager.markAsSynced(operation.id);
        } else {
          results.failure++;
          this.handleFailedOperation(operation);
        }
      } catch (error) {
        console.error(`❌ Operation ${operation.id} failed:`, error);
        results.failure++;
        this.handleFailedOperation(operation);
      }
    }

    return results;
  }

  /**
   * Process individual operation
   */
  private async processOperation(operation: any): Promise<boolean> {
    switch (operation.feature) {
      case 'cash':
        return this.processCashOperation(operation);
      case 'inventory':
        return this.processInventoryOperation(operation);
      case 'calendar':
        return this.processCalendarOperation(operation);
      case 'credit':
        return this.processCreditOperation(operation);
      case 'beehive':
        return this.processBeehiveOperation(operation);
      default:
        console.warn(`Unknown operation feature: ${operation.feature}`);
        return false;
    }
  }

  /**
   * Process cash operations
   */
  private async processCashOperation(operation: any): Promise<boolean> {
    try {
      const response = await fetch('/api/transactions', {
        method: 'POST',
        headers: { 'Content-Type': 'application/json' },
        body: JSON.stringify(operation.data)
      });

      if (!response.ok) {
        throw new Error(`HTTP ${response.status}: ${response.statusText}`);
      }

      const result = await response.json();
      console.log(`💰 Cash operation synced: ${operation.id}`);
      return true;
    } catch (error) {
      console.error(`💰 Cash operation failed:`, error);
      return false;
    }
  }

  /**
   * Process inventory operations
   */
  private async processInventoryOperation(operation: any): Promise<boolean> {
    try {
      const response = await fetch('/api/inventory', {
        method: 'POST',
        headers: { 'Content-Type': 'application/json' },
        body: JSON.stringify(operation.data)
      });

      if (!response.ok) {
        throw new Error(`HTTP ${response.status}: ${response.statusText}`);
      }

      console.log(`📦 Inventory operation synced: ${operation.id}`);
      return true;
    } catch (error) {
      console.error(`📦 Inventory operation failed:`, error);
      return false;
    }
  }

  /**
   * Process calendar operations
   */
  private async processCalendarOperation(operation: any): Promise<boolean> {
    try {
      const response = await fetch('/api/appointments', {
        method: 'POST',
        headers: { 'Content-Type': 'application/json' },
        body: JSON.stringify(operation.data)
      });

      if (!response.ok) {
        throw new Error(`HTTP ${response.status}: ${response.statusText}`);
      }

      console.log(`📅 Calendar operation synced: ${operation.id}`);
      return true;
    } catch (error) {
      console.error(`📅 Calendar operation failed:`, error);
      return false;
    }
  }

  /**
   * Process credit operations
   */
  private async processCreditOperation(operation: any): Promise<boolean> {
    try {
      const response = await fetch('/api/credit', {
        method: 'POST',
        headers: { 'Content-Type': 'application/json' },
        body: JSON.stringify(operation.data)
      });

      if (!response.ok) {
        throw new Error(`HTTP ${response.status}: ${response.statusText}`);
      }

      console.log(`💳 Credit operation synced: ${operation.id}`);
      return true;
    } catch (error) {
      console.error(`💳 Credit operation failed:`, error);
      return false;
    }
  }

  /**
   * Process beehive operations
   */
  private async processBeehiveOperation(operation: any): Promise<boolean> {
    try {
      const response = await fetch('/api/beehive', {
        method: 'POST',
        headers: { 'Content-Type': 'application/json' },
        body: JSON.stringify(operation.data)
      });

      if (!response.ok) {
        throw new Error(`HTTP ${response.status}: ${response.statusText}`);
      }

      console.log(`🐝 Beehive operation synced: ${operation.id}`);
      return true;
    } catch (error) {
      console.error(`🐝 Beehive operation failed:`, error);
      return false;
    }
  }

  /**
   * Handle failed operations with retry logic
   */
  private handleFailedOperation(operation: any) {
    operation.retryCount = (operation.retryCount || 0) + 1;

    if (operation.retryCount >= 3) {
      console.error(`🚨 Operation ${operation.id} exceeded retry limit`);
      offlineQueueManager.markAsFailed(operation.id, 'Max retries exceeded');
      return;
    }

    // Exponential backoff
    const delay = Math.min(1000 * Math.pow(2, operation.retryCount), 30000);
    
    setTimeout(() => {
      this.retryQueue.set(operation.id, operation);
    }, delay);
  }

  /**
   * Group operations by priority
   */
  private groupOperations(operations: any[]): Map<string, any[]> {
    const groups = new Map();
    
    operations.forEach(op => {
      const priority = op.priority || 'medium';
      if (!groups.has(priority)) {
        groups.set(priority, []);
      }
      groups.get(priority).push(op);
    });

    // Order by priority: high -> medium -> low
    const orderedGroups = new Map();
    ['high', 'medium', 'low'].forEach(priority => {
      if (groups.has(priority)) {
        orderedGroups.set(priority, groups.get(priority));
      }
    });

    return orderedGroups;
  }

  /**
   * Create batches for processing
   */
  private createBatches(operations: any[], batchSize: number): any[][] {
    const batches = [];
    for (let i = 0; i < operations.length; i += batchSize) {
      batches.push(operations.slice(i, i + batchSize));
    }
    return batches;
  }

  /**
   * Detect network quality
   */
  private detectNetworkQuality(): NetworkQuality {
    // This would ideally use real network measurement
    const connection = (navigator as any).connection || 
                      (navigator as any).mozConnection || 
                      (navigator as any).webkitConnection;

    if (connection) {
      const downlink = connection.downlink || 1;
      const rtt = connection.rtt || 100;

      if (downlink > 2 && rtt < 200) {
        return {
          type: 'excellent',
          speed: downlink,
          reliability: 0.95,
          recommendedBatchSize: 50,
          timeout: 5000
        };
      } else if (downlink > 1 && rtt < 500) {
        return {
          type: 'good',
          speed: downlink,
          reliability: 0.85,
          recommendedBatchSize: 20,
          timeout: 10000
        };
      } else {
        return {
          type: 'poor',
          speed: downlink,
          reliability: 0.7,
          recommendedBatchSize: 5,
          timeout: 20000
        };
      }
    }

    // Default to good if no connection info
    return {
      type: 'good',
      speed: 1,
      reliability: 0.8,
      recommendedBatchSize: 20,
      timeout: 10000
    };
  }

  /**
   * Setup network monitoring
   */
  private setupNetworkMonitoring() {
    // Monitor network changes and adjust sync strategy
    if ('connection' in navigator) {
      const connection = (navigator as any).connection;
      connection.addEventListener('change', () => {
        this.networkQuality = this.detectNetworkQuality();
        console.log(`🌐 Network quality changed to: ${this.networkQuality.type}`);
      });
    }
  }

  /**
   * Setup network event listeners
   */
  private setupNetworkListeners() {
    connectionDetector.addListener((online: boolean) => {
      if (online) {
        console.log('🌐 Connection restored, triggering sync');
        setTimeout(() => this.processSync(), 1000);
      } else {
        console.log('📴 Connection lost');
        this.notifyListeners('sync-offline');
      }
    });
  }

  /**
   * Update sync metrics
   */
  private updateMetrics(startTime: number, successCount: number, failureCount: number) {
    const duration = Date.now() - startTime;
    
    this.metrics.totalOperations += successCount + failureCount;
    this.metrics.successfulOperations += successCount;
    this.metrics.failedOperations += failureCount;
    this.metrics.lastSyncTime = Date.now();
    
    // Update average sync time
    const totalSyncs = this.metrics.successfulOperations + this.metrics.failedOperations;
    this.metrics.averageSyncTime = 
      (this.metrics.averageSyncTime * (totalSyncs - 1) + duration) / totalSyncs;
  }

  /**
   * Notify listeners of sync status changes
   */
  private notifyListeners(status: string) {
    this.listeners.forEach(listener => listener(status));
  }

  /**
   * Add sync status listener
   */
  addListener(listener: (status: string) => void) {
    this.listeners.add(listener);
  }

  /**
   * Remove sync status listener
   */
  removeListener(listener: (status: string) => void) {
    this.listeners.delete(listener);
  }

  /**
   * Get current metrics
   */
  getMetrics(): SyncMetrics {
    return { ...this.metrics };
  }

  /**
   * Get network quality
   */
  getNetworkQuality(): NetworkQuality {
    return { ...this.networkQuality };
  }

  /**
   * Get retry queue status
   */
  getRetryQueueStatus(): { size: number; items: any[] } {
    return {
      size: this.retryQueue.size,
      items: Array.from(this.retryQueue.values())
    };
  }
}

// Export singleton instance
export const backgroundSyncService = BackgroundSyncService.getInstance();
